{
  "version": "0.4",
  "title": "Blog – Newsletter & Final CTA",
  "type": "page",
  "content": [
    {
      "id": "blog_newsletter",
      "elType": "section",
      "settings": {
        "_title": "Newsletter Signup",
        "layout": "boxed"
      },
      "elements": [
        {
          "id": "newsletter_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "newsletter_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Get Brand Photography Insights Delivered",
                "header_size": "h3",
                "align": "center"
              }
            },
            {
              "id": "newsletter_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Practical advice, creative inspiration, and early access to availability, straight to your inbox. No fluff, no spam.</p>"
              }
            },
            {
              "id": "newsletter_form",
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "XCP Newsletter Signup",
                "form_fields": [
                  {
                    "field_type": "email",
                    "field_label": "Email Address",
                    "field_id": "newsletter_email",
                    "required": "yes",
                    "placeholder": "Your email address",
                    "width": "80"
                  }
                ],
                "submit_actions": [
                  "email"
                ],
                "email_to": "info@xcphotography.co.uk",
                "email_subject": "New Newsletter Signup from XC Photography",
                "email_content": "New newsletter signup:\n\nEmail: {field_id:newsletter_email}",
                "button_text": "Subscribe",
                "button_size": "md",
                "button_align": "left"
              }
            },
            {
              "id": "newsletter_privacy",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>By subscribing you agree to our <a href='/privacy-policy'>Privacy Policy</a>. Unsubscribe at any time.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_cta",
      "elType": "section",
      "settings": {
        "_title": "Final CTA",
        "layout": "boxed"
      },
      "elements": [
        {
          "id": "blog_cta_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "blog_cta_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Ready to Start Your Own Story?",
                "header_size": "h2",
                "align": "center"
              }
            },
            {
              "id": "blog_cta_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Everything you've read here is possible for your brand. Let's talk about what authentic, strategic imagery could do for your business.</p>"
              }
            },
            {
              "id": "blog_cta_button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Book a Free Discovery Call",
                "link": {
                  "url": "/contact",
                  "is_external": false
                },
                "align": "center"
              }
            }
          ]
        }
      ]
    }
  ]
}