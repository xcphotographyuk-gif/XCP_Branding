{
  "version": "0.4",
  "title": "Blog \u2013 Newsletter & Final CTA",
  "type": "section",
  "content": [
    {
      "id": "blog_newsletter",
      "elType": "section",
      "settings": {
        "_title": "Newsletter Signup",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 800
        },
        "background_background": "classic",
        "background_color": "#1a1a1a",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "newsletter_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "newsletter_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Get Brand Photography Insights Delivered",
                "header_size": "h3",
                "align": "center",
                "color": "#FFFFFF",
                "typography_font_size": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 22
                }
              }
            },
            {
              "id": "newsletter_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; color: rgba(255,255,255,0.75); font-size: 16px; max-width: 560px; margin: 16px auto;'>Practical advice, creative inspiration, and early access to availability, straight to your inbox. No fluff, no spam.</p>"
              }
            },
            {
              "id": "newsletter_form",
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "XCP Newsletter Signup",
                "form_fields": [
                  {
                    "field_type": "email",
                    "field_label": "Email Address",
                    "field_id": "newsletter_email",
                    "required": "yes",
                    "placeholder": "Your email address",
                    "width": "80"
                  }
                ],
                "submit_actions": [
                  "email"
                ],
                "button_text": "Subscribe",
                "button_size": "md",
                "button_align": "left",
                "button_background_color": "#E8E4DC",
                "button_text_color": "#000000",
                "button_border_radius": {
                  "unit": "px",
                  "top": "0",
                  "right": "0",
                  "bottom": "0",
                  "left": "0"
                }
              }
            },
            {
              "id": "newsletter_privacy",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; color: rgba(255,255,255,0.45); font-size: 12px; margin-top: 12px;'>By subscribing you agree to our <a href='/privacy-policy' style='color: #E8E4DC;'>Privacy Policy</a>. Unsubscribe at any time.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_cta",
      "elType": "section",
      "settings": {
        "_title": "Final CTA",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 900
        },
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog_cta_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "blog_cta_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Ready to Start Your Own Story?",
                "header_size": "h2",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 26
                }
              }
            },
            {
              "id": "blog_cta_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 17px; color: #555555; max-width: 620px; margin: 20px auto;'>Everything you've read here is possible for your brand. Let's talk about what authentic, strategic imagery could do for your business.</p>"
              }
            },
            {
              "id": "blog_cta_button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Book a Free Discovery Call",
                "link": {
                  "url": "/contact",
                  "is_external": false
                },
                "align": "center",
                "size": "lg",
                "background_color": "#1a1a1a",
                "color": "#FFFFFF",
                "hover_color": "#1a1a1a",
                "button_background_hover_color": "transparent",
                "border_border": "solid",
                "border_width": {
                  "unit": "px",
                  "top": "2",
                  "right": "2",
                  "bottom": "2",
                  "left": "2",
                  "isLinked": true
                },
                "border_color": "#1a1a1a",
                "typography_font_family": "Raleway",
                "typography_font_size": {
                  "unit": "px",
                  "size": 13
                },
                "typography_font_weight": "700",
                "typography_text_transform": "uppercase",
                "typography_letter_spacing": {
                  "unit": "px",
                  "size": 2
                },
                "padding": {
                  "unit": "px",
                  "top": "18",
                  "right": "40",
                  "bottom": "18",
                  "left": "40",
                  "isLinked": false
                }
              }
            }
          ]
        }
      ]
    }
  ]
}