  "_implementation_notes": {
    "page_setup": [
      "Create new WordPress page titled 'Coming Soon' (slug: /coming-soon)",
      "Set Elementor page template to 'Elementor Canvas' (removes header and footer for a standalone experience) — OR keep the standard template if you want the site header/footer visible",
      "Import this JSON via Elementor > My Templates > Import, then apply to the page"
    ],
    "hidden_field_dynamic_tag": [
      "In Elementor form widget, click the 'page_source' field row",
      "In the Default Value field, click the dynamic tag icon (the grid icon)",
      "Select 'Current URL'",
      "This automatically populates the field with the URL of the page the form is on, which Overture receives as a tagged field"
    ],
    "lead_magnet_delivery": [
      "Upload XCP_Lead_Magnet_Services_Guide.pdf (converted from XCP_Lead_Magnet_Services_Guide.md) to WordPress Media Library",
      "Copy the file URL (e.g. https://xcphotography.co/wp-content/uploads/xcp-services-guide.pdf)",
      "In Overture, create an automation: trigger = new contact with tag 'coming-soon-signup' → action = send email with the PDF download link",
      "Alternatively, use Elementor Form > Email action: set the confirmation email body to include the download link — this works without Overture automation and sends immediately on form submission"
    ],
    "overture_tags": [
      "The webhook sends tags: source:coming-soon, signup:pre-launch",
      "The page_source field sends the exact URL",
      "In Overture, create a segment: tag = coming-soon-signup for pre-launch email sequence"
    ],
    "pdf_conversion": [
      "Convert XCP_Lead_Magnet_Services_Guide.md to PDF using: Pandoc (command line), Markdown to PDF VS Code extension, or paste into Google Docs and export",
      "Recommended filename: xcp-photography-services-guide.pdf",
      "Add the XCP logo/header image to the PDF before uploading if possible"
    ]
  }
