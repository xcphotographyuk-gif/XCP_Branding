{
  "version": "0.4",
  "title": "XCP Coming Soon Page — Full Template",
  "_comment": "COMING SOON PAGE: Standalone page template for use before site launch or for specific upcoming service announcements. Includes hero, email sign-up form (Overture webhook), and downloadable services guide link. Palette: #000000 bg, #FFFFFF headings, #E8E4DC accent. Font: Raleway. To use: import into Elementor > Pages > Add New > Import Template. Set page template to 'Elementor Canvas' (no header/footer) or keep header/footer depending on context.",
  "type": "page",
  "content": [

    {
      "id": "cs_hero_section",
      "elType": "section",
      "settings": {
        "_title": "Coming Soon Hero",
        "layout": "full_width",
        "background_background": "classic",
        "background_color": "#000000",
        "padding": {
          "unit": "px",
          "top": "120",
          "right": "40",
          "bottom": "80",
          "left": "40",
          "isLinked": false
        },
        "padding_mobile": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "60",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "cs_hero_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "align": "center"
          },
          "elements": [
            {
              "id": "cs_logo_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='font-family:Raleway,sans-serif;font-size:11px;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:#E8E4DC;margin-bottom:40px;'>XC Photography</p>"
              }
            },
            {
              "id": "cs_eyebrow",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='font-family:Raleway,sans-serif;font-size:12px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:#E8E4DC;margin-bottom:20px;'>Something Is Coming</p>"
              }
            },
            {
              "id": "cs_hero_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Brand Photography That Tells the Truth About Your Business.",
                "header_size": "h1",
                "align": "center",
                "typography_font_family": "Raleway",
                "typography_font_size": {
                  "unit": "px",
                  "size": 56
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 40
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_weight": "800",
                "title_color": "#FFFFFF",
                "max_width": {
                  "unit": "px",
                  "size": 820
                },
                "max_width_mobile": {
                  "unit": "%",
                  "size": 100
                }
              }
            },
            {
              "id": "cs_hero_subtext",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='font-family:Raleway,sans-serif;font-size:18px;font-weight:300;line-height:1.75;color:#cccccc;max-width:600px;margin:24px auto 0;text-align:center;'>XC Photography is launching a new website and expanded services shortly. Leave your details below and be first to know — plus receive a free copy of the XC Photography Services &amp; Workshops Guide.</p>"
              }
            }
          ]
        }
      ]
    },

    {
      "id": "cs_signup_section",
      "elType": "section",
      "settings": {
        "_title": "Sign-Up Form",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 680
        },
        "background_background": "classic",
        "background_color": "#111111",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "40",
          "bottom": "80",
          "left": "40",
          "isLinked": false
        },
        "padding_mobile": {
          "unit": "px",
          "top": "60",
          "right": "20",
          "bottom": "60",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "cs_signup_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "cs_form_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Stay in the Loop",
                "header_size": "h2",
                "align": "center",
                "typography_font_family": "Raleway",
                "typography_font_size": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_weight": "700",
                "title_color": "#FFFFFF"
              }
            },
            {
              "id": "cs_form_subtext",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='font-family:Raleway,sans-serif;font-size:15px;font-weight:300;line-height:1.7;color:#aaaaaa;text-align:center;margin:12px 0 32px;'>Sign up for early access, workshop announcements, and availability updates. One email when it matters. Never spam.</p>"
              }
            },
            {
              "id": "cs_signup_form_widget",
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "XCP Coming Soon Sign-Up",
                "_comment": "This form routes to Overture via webhook. The page_source hidden field is auto-populated with the current page URL — in Elementor, set Default Value of this field to the 'Current URL' dynamic tag. The form also triggers a confirmation email with a link to download XCP_Lead_Magnet_Services_Guide.pdf.",
                "form_fields": [
                  {
                    "field_type": "text",
                    "field_label": "Your Name",
                    "field_id": "name",
                    "required": "yes",
                    "placeholder": "First name",
                    "width": "50"
                  },
                  {
                    "field_type": "email",
                    "field_label": "Email Address",
                    "field_id": "email",
                    "required": "yes",
                    "placeholder": "hello@yourbusiness.co.uk",
                    "width": "50"
                  },
                  {
                    "field_type": "hidden",
                    "field_label": "Page Source",
                    "field_id": "page_source",
                    "required": "no",
                    "default_value": "[xcp_page_url]",
                    "width": "100",
                    "_comment": "Set Default Value to 'Current URL' dynamic tag in Elementor. Tags the Overture contact with the coming soon page URL."
                  },
                  {
                    "field_type": "hidden",
                    "field_label": "Lead Source Tag",
                    "field_id": "lead_tag",
                    "required": "no",
                    "default_value": "coming-soon-signup",
                    "width": "100",
                    "_comment": "Static tag sent to Overture to identify this as a coming-soon page lead. Enables segmented follow-up."
                  },
                  {
                    "field_type": "acceptance",
                    "field_label": "Yes — send me the free XC Photography Services &amp; Workshops Guide and keep me updated on the launch.",
                    "field_id": "marketing_optin",
                    "required": "yes",
                    "width": "100",
                    "custom_messages": "yes",
                    "required_message": "Please tick this box to receive your guide and updates."
                  },
                  {
                    "field_type": "acceptance",
                    "field_label": "I have read and agree to the <a href='/privacy-policy' target='_blank' style='color:#E8E4DC;text-decoration:underline;'>Privacy Policy</a>.",
                    "field_id": "gdpr_consent",
                    "required": "yes",
                    "width": "100",
                    "custom_messages": "yes",
                    "required_message": "Please confirm you have read and agree to the Privacy Policy."
                  }
                ],
                "submit_actions": [
                  "email",
                  "webhook"
                ],
                "webhook": "https://api.overture.studio/v1/enquiries",
                "webhook_advanced_data": "yes",
                "webhook_tags": "source:coming-soon,signup:pre-launch",
                "button_text": "Get My Free Guide",
                "button_size": "lg",
                "button_align": "stretch",
                "button_background_color": "#E8E4DC",
                "button_text_color": "#000000",
                "button_border_radius": {
                  "unit": "px",
                  "top": "0",
                  "right": "0",
                  "bottom": "0",
                  "left": "0",
                  "isLinked": true
                },
                "button_padding": {
                  "unit": "px",
                  "top": "18",
                  "right": "40",
                  "bottom": "18",
                  "left": "40",
                  "isLinked": false
                },
                "typography_font_family": "Raleway",
                "success_message": "You're on the list. Check your inbox — your copy of the XC Photography Services &amp; Workshops Guide is on its way. See you on the other side.",
                "error_message": "Something went wrong. Please email hello@xcphotography.co.uk directly and we'll sort it."
              }
            }
          ]
        }
      ]
    },

