{
  "version": "0.4",
  "title": "XCP Contact Hero: Section 1 of 4",
  "type": "page",
  "content": [
    {
      "id": "contact_hero",
      "elType": "section",
      "settings": {
        "_title": "Contact Hero",
        "layout": "full_width",
        "background_image": {
          "url": "[uc_local]assets/images/contact-hero.jpg"
        },
        "content_position": "middle"
      },
      "elements": [
        {
          "id": "contact_hero_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "contact_eyebrow",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Let's Work Together</p>"
              }
            },
            {
              "id": "contact_title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Let's Bring Your Vision to Life",
                "header_size": "h1",
                "align": "center"
              }
            },
            {
              "id": "contact_subtitle",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Your story deserves to be told with intention, authenticity, and visual impact. I work with businesses across Brighton, across the UK, and internationally. Let's start the conversation.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}