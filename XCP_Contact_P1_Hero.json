{
  "version": "0.4",
  "title": "XCP Contact Hero: Section 1 of 4",
  "type": "page",
  "content": [
    {
      "id": "contact_hero",
      "elType": "section",
      "settings": {
        "_title": "Contact Hero",
        "layout": "full_width",
        "min_height": {
          "unit": "vh",
          "size": 55
        },
        "background_background": "classic",
        "background_image": {
          "url": "[uc_local]assets/images/contact-hero.jpg"
        },
        "background_position": "center center",
        "background_size": "cover",
        "background_attachment": "scroll",
        "background_overlay_background": "classic",
        "background_overlay_color": "rgba(0,0,0,0.55)",
        "content_position": "middle",
        "padding": {
          "unit": "%",
          "top": "10",
          "right": "5",
          "bottom": "10",
          "left": "5",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "contact_hero_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "contact_eyebrow",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align:center;color:#E8E4DC;font-size:13px;letter-spacing:3px;text-transform:uppercase;font-weight:600;margin-bottom:16px;font-family:Raleway,sans-serif;'>Let's Work Together</p>"
              }
            },
            {
              "id": "contact_title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Let's Bring Your Vision to Life",
                "header_size": "h1",
                "align": "center",
                "color": "#ffffff",
                "typography_font_family": "Raleway",
                "typography_font_size": {
                  "unit": "px",
                  "size": 52
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_weight": "700"
              }
            },
            {
              "id": "contact_subtitle",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align:center;font-size:19px;line-height:1.8;color:rgba(255,255,255,0.88);max-width:680px;margin:20px auto 0;'>Your story deserves to be told with intention, authenticity, and visual impact. I work with businesses across Brighton, across the UK, and internationally. Let's start the conversation.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}