{
  "version": "0.4",
  "title": "Services – Transformation & Bespoke",
  "type": "page",
  "content": [
    {
      "id": "service_package_3",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "_title": "Brand Transformation Package"
      },
      "elements": [
        {
          "id": "pkg3_img_col",
          "elType": "column",
          "settings": {},
          "elements": [
            {
              "id": "pkg3_image",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": {
                  "url": "[uc_local]assets/images/services/package-transformation.jpg"
                },
                "image_size": "large"
              }
            }
          ]
        },
        {
          "id": "pkg3_content_col",
          "elType": "column",
          "settings": {
            "content_position": "middle"
          },
          "elements": [
            {
              "id": "pkg3_label",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Premium Experience</p>"
              }
            },
            {
              "id": "pkg3_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Brand Transformation",
                "header_size": "h3"
              }
            },
            {
              "id": "pkg3_description",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Complete visual rebrand or extensive content library creation. A true partnership investment in your brand's future.</p><p><strong>What's Included:</strong></p><ul><li>Multi-day strategic photography project</li><li>Comprehensive brand strategy sessions</li><li>100+ professionally edited images</li><li>Multiple locations, concepts, & setups</li><li>Team headshots, environmental, lifestyle, product</li><li>Behind-the-scenes content capture</li><li>All formats optimized for every platform</li><li>Full commercial usage rights</li><li>12-month ongoing support & consulting</li><li>Quarterly refresh sessions available</li></ul><p><strong>Ideal For:</strong> Organizations ready for comprehensive brand transformation</p>"
              }
            },
            {
              "id": "pkg3_cta",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Transform Your Brand",
                "link": {
                  "url": "#contact"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "service_bespoke",
      "elType": "section",
      "settings": {
        "_title": "Bespoke Enquiry",
        "layout": "boxed"
      },
      "elements": [
        {
          "id": "bespoke_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "bespoke_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Bespoke Visual Storytelling",
                "header_size": "h2",
                "align": "center"
              }
            },
            {
              "id": "bespoke_intro",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Your brand has a story. I help you tell it through powerful, authentic, and cinematic imagery. For a detailed discussion about your project, please use the enquiry form below.</p>"
              }
            },
            {
              "id": "bespoke_form",
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "Bespoke Project Enquiry",
                "form_fields": [
                  {
                    "field_type": "text",
                    "required": "true",
                    "label": "Full Name",
                    "placeholder": "Full Name",
                    "width": "50"
                  },
                  {
                    "field_type": "email",
                    "required": "true",
                    "label": "Email Address",
                    "placeholder": "Email Address",
                    "width": "50"
                  },
                  {
                    "field_type": "tel",
                    "required": "false",
                    "label": "Phone Number",
                    "placeholder": "Phone Number (Optional)",
                    "width": "50"
                  },
                  {
                    "field_type": "text",
                    "required": "false",
                    "label": "Business Name",
                    "placeholder": "Business Name",
                    "width": "50"
                  },
                  {
                    "field_type": "date",
                    "required": "false",
                    "label": "Project Date (Approximate)",
                    "placeholder": "Project Date (Approximate)",
                    "width": "50"
                  },
                  {
                    "field_type": "select",
                    "required": "true",
                    "label": "Service of Interest",
                    "placeholder": "Service of Interest",
                    "field_options": "Brand Foundation\nBrand Elevation\nBrand Transformation\nBespoke Project",
                    "width": "50"
                  },
                  {
                    "field_type": "textarea",
                    "required": "true",
                    "label": "Tell me about your project",
                    "placeholder": "Tell me about your project",
                    "width": "100",
                    "rows": "6"
                  },
                  {
                    "field_type": "upload",
                    "required": "false",
                    "label": "Attach brief / moodboard",
                    "placeholder": "Attach brief / moodboard (optional)",
                    "width": "100"
                  }
                ],
                "submit": {
                  "value": "Send Enquiry",
                  "size": "md"
                },
                "email": {
                  "to": "xavier@xcphotography.co.uk",
                  "subject": "New Bespoke Project Enquiry",
                  "from_name": "XC Photography Website",
                  "from_email": "noreply@xcphotography.co.uk"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}