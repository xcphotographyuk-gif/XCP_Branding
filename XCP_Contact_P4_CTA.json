{
  "version": "0.4",
  "title": "XCP Contact: Closing CTA: Section 4 of 4",
  "type": "page",
  "content": [
    {
      "id": "contact_final_cta",
      "elType": "section",
      "settings": {
        "_title": "Closing CTA",
        "layout": "boxed"
      },
      "elements": [
        {
          "id": "final_cta_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "final_cta_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Your Audience Is Waiting",
                "header_size": "h3",
                "align": "center"
              }
            },
            {
              "id": "final_cta_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Every day without authentic, strategic imagery is a day your ideal clients connect with someone else. I typically respond within 24 hours with next steps for a no-pressure discovery call.</p>"
              }
            },
            {
              "id": "final_cta_button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Book Your Discovery Call",
                "link": {
                  "url": "/booking",
                  "is_external": false,
                  "nofollow": false
                },
                "align": "center"
              }
            }
          ]
        }
      ]
    }
  ]
}