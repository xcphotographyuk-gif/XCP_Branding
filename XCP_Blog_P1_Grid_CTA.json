{
  "version": "0.4",
  "title": "XCP Blog & Stories Page",
  "type": "page",
  "content": [
    {
      "id": "blog_hero",
      "elType": "section",
      "settings": {
        "_title": "Blog Hero",
        "layout": "full_width",
        "min_height": {
          "unit": "vh",
          "size": 55
        },
        "background_background": "classic",
        "background_image": {
          "url": "[uc_local]assets/images/blog-hero.jpg"
        },
        "background_position": "center center",
        "background_size": "cover",
        "background_attachment": "scroll",
        "background_overlay_background": "classic",
        "background_overlay_color": "rgba(0,0,0,0.55)",
        "content_position": "middle",
        "padding": {
          "unit": "%",
          "top": "8",
          "right": "5",
          "bottom": "8",
          "left": "5",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog_hero_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_hero_label",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; color: #E8E4DC; font-size: 13px; letter-spacing: 3px; text-transform: uppercase; font-weight: 600; margin-bottom: 16px;'>Insights &amp; Inspiration</p>"
              }
            },
            {
              "id": "blog_hero_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Stories That Inform, Inspire, and Connect",
                "header_size": "h1",
                "align": "center",
                "color": "#FFFFFF",
                "typography_font_family": "Montserrat",
                "typography_font_size": {
                  "unit": "px",
                  "size": 52
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_weight": "700"
              }
            },
            {
              "id": "blog_hero_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; color: rgba(255,255,255,0.85); font-size: 18px; line-height: 1.8; max-width: 680px; margin: 20px auto 0;'>Brand photography insights, industry expertise, and creative inspiration for businesses ready to elevate their visual presence.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_featured",
      "elType": "section",
      "settings": {
        "_title": "Featured Post",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1200
        },
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "40",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog_featured_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_featured_label",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Latest from the Blog",
                "header_size": "h2",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 26
                }
              }
            },
            {
              "id": "blog_featured_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 17px; color: #555555; max-width: 650px; margin: 16px auto 0;'>Practical advice and creative strategies for brands ready to show up authentically.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_posts_grid",
      "elType": "section",
      "settings": {
        "_title": "Blog Posts Grid",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1200
        },
        "structure": "33",
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": "40",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        },
        "gap": "wide"
      },
      "elements": [
        {
          "id": "blog_posts_widget_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_posts_widget",
              "elType": "widget",
              "widgetType": "posts",
              "settings": {
                "posts_per_page": 6,
                "show_title": "yes",
                "show_date": "yes",
                "show_excerpt": "yes",
                "show_read_more": "yes",
                "read_more_text": "Read Article",
                "show_image": "yes",
                "image_ratio": "0.5",
                "meta_data": [
                  "author",
                  "date"
                ],
                "columns": 3,
                "columns_tablet": 2,
                "columns_mobile": 1,
                "image_size": "medium_large",
                "item_ratio": {
                  "unit": "%",
                  "size": 55
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_categories",
      "elType": "section",
      "settings": {
        "_title": "Category Filter",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1200
        },
        "background_background": "classic",
        "background_color": "#F5F5F5",
        "padding": {
          "unit": "px",
          "top": "60",
          "right": "20",
          "bottom": "60",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog_cat_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "blog_cat_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Browse by Topic",
                "header_size": "h3",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 28
                }
              }
            },
            {
              "id": "blog_cat_links",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: 24px;'><a href='/stories/category/music-nightlife' style='display: inline-block; padding: 10px 24px; border: 1px solid #1a1a1a; color: #1a1a1a; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;'>Music &amp; Nightlife</a><a href='/stories/category/brand-photography' style='display: inline-block; padding: 10px 24px; border: 1px solid #1a1a1a; color: #1a1a1a; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;'>Brand Photography</a><a href='/stories/category/behind-the-scenes' style='display: inline-block; padding: 10px 24px; border: 1px solid #1a1a1a; color: #1a1a1a; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;'>Behind the Scenes</a><a href='/stories/category/client-stories' style='display: inline-block; padding: 10px 24px; border: 1px solid #1a1a1a; color: #1a1a1a; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;'>Client Stories</a><a href='/stories/category/gear-guides' style='display: inline-block; padding: 10px 24px; border: 1px solid #1a1a1a; color: #1a1a1a; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;'>Gear Guides</a><a href='/stories/category/photography-tips' style='display: inline-block; padding: 10px 24px; border: 1px solid #1a1a1a; color: #1a1a1a; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;'>Photography Tips</a></div>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_newsletter",
      "elType": "section",
      "settings": {
        "_title": "Newsletter Signup",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 800
        },
        "background_background": "classic",
        "background_color": "#1a1a1a",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "newsletter_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "newsletter_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Get Brand Photography Insights Delivered",
                "header_size": "h3",
                "align": "center",
                "color": "#FFFFFF",
                "typography_font_size": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 22
                }
              }
            },
            {
              "id": "newsletter_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; color: rgba(255,255,255,0.75); font-size: 16px; max-width: 560px; margin: 16px auto;'>Practical advice, creative inspiration, and early access to availability, straight to your inbox. No fluff, no spam.</p>"
              }
            },
            {
              "id": "newsletter_form",
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "XCP Newsletter Signup",
                "form_fields": [
                  {
                    "field_type": "email",
                    "field_label": "Email Address",
                    "field_id": "newsletter_email",
                    "required": "yes",
                    "placeholder": "Your email address",
                    "width": "80"
                  }
                ],
                "submit_actions": [
                  "email"
                ],
                "button_text": "Subscribe",
                "button_size": "md",
                "button_align": "left",
                "button_background_color": "#E8E4DC",
                "button_text_color": "#000000",
                "button_border_radius": {
                  "unit": "px",
                  "top": "0",
                  "right": "0",
                  "bottom": "0",
                  "left": "0"
                }
              }
            },
            {
              "id": "newsletter_privacy",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; color: rgba(255,255,255,0.45); font-size: 12px; margin-top: 12px;'>By subscribing you agree to our <a href='/privacy-policy' style='color: #E8E4DC;'>Privacy Policy</a>. Unsubscribe at any time.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_cta",
      "elType": "section",
      "settings": {
        "_title": "Final CTA",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 900
        },
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog_cta_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "blog_cta_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Ready to Start Your Own Story?",
                "header_size": "h2",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 26
                }
              }
            },
            {
              "id": "blog_cta_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 17px; color: #555555; max-width: 620px; margin: 20px auto;'>Everything you've read here is possible for your brand. Let's talk about what authentic, strategic imagery could do for your business.</p>"
              }
            },
            {
              "id": "blog_cta_button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Book a Free Discovery Call",
                "link": {
                  "url": "/contact",
                  "is_external": false
                },
                "align": "center",
                "size": "lg",
                "background_color": "#1a1a1a",
                "color": "#FFFFFF",
                "hover_color": "#1a1a1a",
                "button_background_hover_color": "transparent",
                "border_border": "solid",
                "border_width": {
                  "unit": "px",
                  "top": "2",
                  "right": "2",
                  "bottom": "2",
                  "left": "2",
                  "isLinked": true
                },
                "border_color": "#1a1a1a",
                "typography_font_family": "Montserrat",
                "typography_font_size": {
                  "unit": "px",
                  "size": 13
                },
                "typography_font_weight": "700",
                "typography_text_transform": "uppercase",
                "typography_letter_spacing": {
                  "unit": "px",
                  "size": 2
                },
                "padding": {
                  "unit": "px",
                  "top": "18",
                  "right": "40",
                  "bottom": "18",
                  "left": "40",
                  "isLinked": false
                }
              }
            }
          ]
        }
      ]
    }
  ]
}