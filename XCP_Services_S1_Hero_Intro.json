{
  "version": "0.4",
  "title": "Services \u2013 Hero & Intro",
  "type": "section",
  "content": [
    {
      "id": "services_hero",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "min_height": {
          "unit": "vh",
          "size": 70
        },
        "background_background": "classic",
        "background_image": {
          "url": "[uc_local]assets/images/services/hero-services.jpg"
        },
        "background_position": "center center",
        "background_size": "cover",
        "background_overlay_background": "classic",
        "background_overlay_color": "rgba(0,0,0,0.5)",
        "content_position": "middle",
        "padding": {
          "unit": "px",
          "top": 100,
          "right": 20,
          "bottom": 100,
          "left": 20
        },
        "_title": "Services Hero"
      },
      "elements": [
        {
          "id": "services_hero_col",
          "elType": "column",
          "settings": {
            "width": {
              "unit": "%",
              "size": 100
            }
          },
          "elements": [
            {
              "id": "services_hero_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Brand Photography in Brighton and Across the UK",
                "header_size": "h1",
                "align": "center",
                "title_color": "#FFFFFF",
                "typography_font_size": {
                  "unit": "px",
                  "size": 56
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 42
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 32
                }
              }
            },
            {
              "id": "services_hero_subhead",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; color: #FFFFFF; font-size: 20px; max-width: 700px; margin: 20px auto;'>Strategic photography packages built on a decade of active visual work, designed to help the right brands show up in a way that commands genuine attention.</p>",
                "align": "center"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "services_intro",
      "elType": "section",
      "settings": {
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1200
        },
        "padding": {
          "unit": "px",
          "top": 80,
          "right": 20,
          "bottom": 40,
          "left": 20
        },
        "_title": "Services Intro"
      },
      "elements": [
        {
          "id": "services_intro_col",
          "elType": "column",
          "settings": {
            "width": {
              "unit": "%",
              "size": 100
            }
          },
          "elements": [
            {
              "id": "services_intro_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "What You're Actually Getting",
                "header_size": "h2",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 42
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 28
                }
              }
            },
            {
              "id": "services_intro_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 18px; max-width: 800px; margin: 30px auto; line-height: 1.8;'>You're not buying photographs. You're getting a process that starts long before the camera comes out, and imagery that reflects who you actually are when it does. Every package is built around getting that part right first.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}