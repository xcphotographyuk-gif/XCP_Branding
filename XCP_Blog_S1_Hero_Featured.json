              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Music and Events Coverage",
                "header_size": "h3"
              }
            },
            {
              "id": "blog_card2_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Behind-the-scenes stories, artist portraits, and live performance photography from over a decade shooting on stage, backstage, and in the pit. The real world of music photography.</p><p><a href='/stories/category/music-nightlife'>Read music and events articles</a></p>"
              }
            }
          ]
        },
        {
          "id": "blog_card3_col",
          "elType": "column",
          "settings": {
            "_column_size": 33,
            "_column_size_tablet": 100,
            "_column_size_mobile": 100
          },
          "elements": [
            {
              "id": "blog_card3_image",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": {
                  "url": "[uc_local]assets/images/blog-gear-guides.jpg"
                },
                "image_size": "medium_large",
                "caption_source": "none"
              }
            },
            {
              "id": "blog_card3_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "For Photographers",
                "header_size": "h3"
              }
            },
            {
              "id": "blog_card3_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Honest gear reviews, lighting technique, Lightroom workflows, and thoughts on running a photography business. Kit I own and use, reviewed without sponsorship or pressure.</p><p><a href='/stories/category/gear-reviews'>Read photographer guides</a></p>"
              }
            }
          ]
        }
      ]
    }
