{
  "version": "0.4",
  "title": "Blog – Hero & Featured Post",
  "type": "page",
  "content": [
    {
      "id": "blog_hero",
      "elType": "section",
      "settings": {
        "_title": "Blog Hero",
        "layout": "full_width",
        "min_height": {
          "unit": "vh",
          "size": 55
        },
        "background_background": "classic",
        "background_image": {
          "url": "[uc_local]assets/images/blog-hero.jpg"
        },
        "background_position": "center center",
        "background_size": "cover",
        "background_attachment": "scroll",
        "background_overlay_background": "classic",
        "background_overlay_color": "rgba(0,0,0,0.55)",
        "content_position": "middle",
        "padding": {
          "unit": "%",
          "top": "8",
          "right": "5",
          "bottom": "8",
          "left": "5",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog_hero_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_hero_label",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Insights &amp; Inspiration</p>"
              }
            },
            {
              "id": "blog_hero_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Stories That Inform, Inspire, and Connect",
                "header_size": "h1",
                "align": "center",
                "color": "#FFFFFF",
                "typography_font_family": "Raleway",
                "typography_font_size": {
                  "unit": "px",
                  "size": 52
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_weight": "700"
              }
            },
            {
              "id": "blog_hero_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Brand photography insights, industry expertise, and creative inspiration for businesses ready to elevate their visual presence.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_featured",
      "elType": "section",
      "settings": {
        "_title": "Featured Post",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1200
        },
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "40",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog_featured_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_featured_label",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Latest from the Blog",
                "header_size": "h2",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 26
                }
              }
            },
            {
              "id": "blog_featured_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Practical advice and creative strategies for brands ready to show up authentically.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}