{
  "version": "0.4",
  "title": "Blog – Hero & Topic Showcase",
  "type": "page",
  "content": [
    {
      "id": "blog_hero",
      "elType": "section",
      "settings": {
        "_title": "Blog Hero",
        "layout": "full_width",
        "background_image": {
          "url": "[uc_local]assets/images/blog-hero.jpg"
        },
        "content_position": "middle"
      },
      "elements": [
        {
          "id": "blog_hero_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_hero_label",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Stories, Insights and Inspiration</p>"
              }
            },
            {
              "id": "blog_hero_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Real Photography. Real Business. Real Results.",
                "header_size": "h1",
                "align": "center"
              }
            },
            {
              "id": "blog_hero_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Brand photography insights, honest kit reviews, music and events coverage, and behind-the-scenes stories from a working photographer. Written for business owners and photographers alike.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_topic_intro",
      "elType": "section",
      "settings": {
        "_title": "What You Will Find Here",
        "layout": "boxed"
      },
      "elements": [
        {
          "id": "blog_topic_col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "blog_topic_label",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Three Reasons to Read",
                "header_size": "h2",
                "align": "center"
              }
            },
            {
              "id": "blog_topic_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Not just a portfolio blog. Practical content for brands and photographers.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_topic_cards",
      "elType": "section",
      "settings": {
        "_title": "Topic Cards",
        "layout": "boxed",
        "structure": "33"
