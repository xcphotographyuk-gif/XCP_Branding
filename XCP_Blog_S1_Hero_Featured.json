              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "For Business Owners",
                "header_size": "h3"
              }
            },
            {
              "id": "blog_card1_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>How to brief a photographer, what to expect from a brand shoot, how to get more from your images, and why visual identity matters more than most brands realise.</p><p><a href='/stories/category/brand-photography'>Read brand photography articles</a></p>"
              }
            }
          ]
        },
        {
          "id": "blog_card2_col",
          "elType": "column",
          "settings": {
            "_column_size": 33,
            "_column_size_tablet": 50,
            "_column_size_mobile": 100
