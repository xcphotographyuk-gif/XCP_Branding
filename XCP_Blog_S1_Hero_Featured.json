{
  "version": "0.4",
  "title": "Blog – Hero & Featured Post",
  "type": "page",
  "content": [
    {
      "id": "blog_hero",
      "elType": "section",
      "settings": {
        "_title": "Blog Hero",
        "layout": "full_width",
        "background_image": {
          "url": "[uc_local]assets/images/blog-hero.jpg"
        },
        "content_position": "middle"
      },
      "elements": [
        {
          "id": "blog_hero_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_hero_label",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Insights &amp; Inspiration</p>"
              }
            },
            {
              "id": "blog_hero_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Stories That Inform, Inspire, and Connect",
                "header_size": "h1",
                "align": "center"
              }
            },
            {
              "id": "blog_hero_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Brand photography insights, industry expertise, and creative inspiration for businesses ready to elevate their visual presence.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "blog_featured",
      "elType": "section",
      "settings": {
        "_title": "Featured Post",
        "layout": "boxed"
      },
      "elements": [
        {
          "id": "blog_featured_col",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "blog_featured_label",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Latest from the Blog",
                "header_size": "h2",
                "align": "center"
              }
            },
            {
              "id": "blog_featured_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Practical advice and creative strategies for brands ready to show up authentically.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}