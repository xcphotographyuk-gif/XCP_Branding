              "id": "blog_card2_image",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": {
                  "url": "[uc_local]assets/images/blog-music-events.jpg"
                },
                "image_size": "medium_large",
                "caption_source": "none"
              }
            },
            {
