                  "size": 36
                },
                "typography_font_weight": "700"
              }
            },
            {
              "id": "faq_accordion",
              "elType": "widget",
              "widgetType": "accordion",
              "settings": {
                "tabs": [
                  {
                    "tab_title": "Do I need to prepare anything before the call?",
                    "tab_content": "Not at all. Just show up as you are. If you have a few thoughts about your brand or some visual references you love, feel free to share them, but it's absolutely not required. The conversation will naturally surface everything we need."
                  },
                  {
                    "tab_title": "How quickly will I get a proposal after the call?",
                    "tab_content": "If we're a great fit, you'll receive a tailored proposal within 48 hours of your discovery call. It will include a recommended package, an outline of what we'll create together, and investment details."
                  },
                  {
                    "tab_title": "What if I'm not ready to book but want to learn more?",
                    "tab_content": "That's completely fine. The discovery call is exactly the right place to start. There's no expectation to commit on the day. Many of our best client relationships began with a relaxed exploratory conversation months before the shoot."
                  },
                  {
                    "tab_title": "Do you work with clients outside Brighton?",
                    "tab_content": "Yes, XC Photography shoots across the UK. We travel for the right brief. Travel costs for locations more than 50 miles from Brighton are outlined transparently in your proposal."
                  },
                  {
                    "tab_title": "What if I need to reschedule?",
                    "tab_content": "No problem at all. Use the reschedule link in your booking confirmation email, or email hello@xcphotography.uk and we'll sort it within the hour."
                  }
                ],
                "active_item": 1,
                "title_html_tag": "h4",
                "title_typography_font_family": "Raleway",
                "title_typography_font_weight": "600",
                "title_typography_font_size": {
                  "unit": "px",
                  "size": 17
                }
              }
            }
          ]
        }
      ]
