            {
              "id": "booking_calendar_embed",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<!-- Overture / Calendly booking calendar embed -->\n<!-- Replace the src URL below with your Overture or Calendly embed URL -->\n<!-- Overture embed: Overture Admin → Booking Pages → Embed Code -->\n<!-- Calendly embed: calendly.com/[your-username]/discovery-call -->\n<div style=\"min-width:320px; height:700px;\">\n  <iframe\n    src=\"https://calendly.com/xcphotographyuk/discovery-call\"\n    width=\"100%\"\n    height=\"700\"\n    title=\"Book a Discovery Call with XC Photography\"\n    loading=\"lazy\"\n    sandbox=\"allow-forms allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox\"\n    allow=\"payment; geolocation\"\n    style=\"border: none; border-radius: 4px;\"\n  ></iframe>\n</div>",
                "_element_custom_width": "100"
              }
            }
          ]
