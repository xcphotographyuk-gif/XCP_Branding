          "settings": {
            "_column_size": 40,
            "_column_size_tablet": 100,
            "_column_size_mobile": 100
          },
          "elements": [
            {
              "id": "booking_what_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "What Happens on the Call?",
                "header_size": "h3",
                "typography_font_family": "Raleway",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "typography_font_weight": "700"
              }
            },
            {
              "id": "booking_what_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<ul style='list-style: none; padding: 0; margin: 0 0 30px;'><li style='padding: 10px 0; border-bottom: 1px solid #e8e8e8; font-size: 16px; line-height: 1.6;'>🎯 &nbsp;<strong>We learn about your brand</strong>: your goals, your audience, and the story you want to tell.</li><li style='padding: 10px 0; border-bottom: 1px solid #e8e8e8; font-size: 16px; line-height: 1.6;'>📸 &nbsp;<strong>We explore your vision</strong>: the look, feel, and emotional impact you're aiming for.</li><li style='padding: 10px 0; border-bottom: 1px solid #e8e8e8; font-size: 16px; line-height: 1.6;'>💡 &nbsp;<strong>We share ideas</strong>: concepts, locations, and approaches that fit your brand perfectly.</li><li style='padding: 10px 0; border-bottom: 1px solid #e8e8e8; font-size: 16px; line-height: 1.6;'>✅ &nbsp;<strong>We assess fit</strong>, because the best work happens when photographer and client are genuinely aligned.</li><li style='padding: 10px 0; font-size: 16px; line-height: 1.6;'>📋 &nbsp;<strong>Next steps</strong>: if it's a great fit, we'll outline a tailored proposal. No pressure either way.</li></ul>"
              }
            },
            {
              "id": "booking_duration_box",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='background: #1a1a1a; color: #ffffff; padding: 24px; border-left: 4px solid #E8E4DC; margin-bottom: 30px;'><p style='margin: 0 0 6px; font-family: Raleway, sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #E8E4DC;'>The Details</p><p style='margin: 0; font-size: 15px; line-height: 1.7;'>📅 <strong>30 minutes</strong> via Zoom or phone<br>📍 Available UK-wide<br>🎁 <strong>Completely free</strong>, no obligation<br>⏱ Response within 24 hours of booking</p></div>"
              }
