          },
          "elements": [
            {
              "id": "faq_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Frequently Asked Questions",
                "header_size": "h2",
                "align": "center",
                "typography_font_family": "Raleway",
