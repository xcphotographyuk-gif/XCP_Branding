              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Work I do purely for myself, places I explore with a camera, and ongoing personal projects that may or may not ever become anything. Authentic, unfiltered and often unrelated to branding photography entirely.</p><p><a href='/stories/category/personal-projects' style='color:#d4af37;text-decoration:none;'>See personal projects</a></p>"
