            {
              "id": "blog_s5_bts_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>The stuff that does not make it into a portfolio. The failed attempts, the strange locations, the things I tried that did not work, and occasionally something that worked better than expected. General BTS notes written with client privacy protected.</p><p><a href='/stories/category/behind-the-lens' style='color:#d4af37;text-decoration:none;'>Read behind-the-lens posts</a></p>"
              }
            }
