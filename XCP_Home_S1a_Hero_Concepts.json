{
  "version": "0.4",
  "title": "XCP Home S1a - Hero + Concept Boxes",
  "type": "page",
  "content": [
    {
      "id": "hero-section",
      "elType": "section",
      "settings": {
        "_title": "Hero Section",
        "layout": "full_width",
        "background_image": {
          "url": "[uc_local]assets/images/hero/homepage-hero.jpg"
        },
        "content_position": "middle",
        "flex_direction": "column",
        "flex_align_items": "center",
        "flex_justify_content": "center"
      },
      "elements": [
        {
          "id": "hero-content",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "content_position": "middle"
          },
          "elements": [
            {
              "id": "hero-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Branding & Documentary Photography That Demands Attention",
                "header_size": "h1",
                "align": "center"
              }
            },
            {
              "id": "hero-subheading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Iconic Imagery for Iconic Brands with an Edge",
                "header_size": "h2",
                "align": "center"
              }
            },
            {
              "id": "hero-cta-primary",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Book a Consultation",
                "link": {
                  "url": "/booking"
                },
                "align": "center"
              }
            },
            {
              "id": "hero-cta-secondary",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "View Portfolio",
                "link": {
                  "url": "/portfolio"
                },
                "align": "center",
                "button_type": "outline"
              }
            }
          ]
        }
      ]
    },
    {
