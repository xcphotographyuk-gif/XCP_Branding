{
  "version": "0.4",
  "title": "About – Hero",
  "type": "page",
  "content": [
    {
      "id": "about_hero",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "min_height": {
          "unit": "vh",
          "size": 70
        },
        "background_background": "classic",
        "background_image": {
          "url": "[uc_local]assets/images/about/hero-partnership.jpg"
        },
        "background_position": "center center",
        "background_size": "cover",
        "background_overlay_background": "classic",
        "background_overlay_color": "rgba(0,0,0,0.4)",
        "content_position": "middle",
        "padding": {
          "unit": "px",
          "top": 100,
          "right": 20,
          "bottom": 100,
          "left": 20
        },
        "_title": "About Hero"
      },
      "elements": [
        {
          "id": "about_hero_col",
          "elType": "column",
          "settings": {
            "width": {
              "unit": "%",
              "size": 100
            },
            "width_tablet": {
              "unit": "%",
              "size": 100
            },
            "width_mobile": {
              "unit": "%",
              "size": 100
            }
          },
          "elements": [
            {
              "id": "about_hero_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Who Takes Your Photographs Matters",
                "header_size": "h1",
                "align": "center",
                "align_tablet": "center",
                "align_mobile": "center",
                "title_color": "#FFFFFF",
                "typography_font_size": {
                  "unit": "px",
                  "size": 56
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 42
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 32
                }
              }
            },
            {
              "id": "about_hero_subhead",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Partnership, not just photography. Your vision, elevated through imagery that truly reflects who you are and connects with the people who were always meant to find you.</p>",
                "align": "center"
              }
            }
          ]
        }
      ]
    }
  ]
}