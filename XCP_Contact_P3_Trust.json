            {
              "id": "trust_p1_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Over ten years shooting brands, artists, and live events across the UK and internationally. Every shoot is informed by real commercial experience, not just technique.</p>"
