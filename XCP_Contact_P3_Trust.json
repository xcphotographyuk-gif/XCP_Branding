                "title": "Strategic, Not Just Beautiful",
                "header_size": "h3"
              }
            },
            {
              "id": "trust_p2_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Great photography has a job to do. Every image is designed around your business goals, your audience, and where the images will be used. Looks matter. Results matter more.</p>"
              }
            }
          ]
        },
        {
          "id": "trust_col3",
          "elType": "column",
          "settings": {
            "_column_size": 33,
            "_column_size_tablet": 100,
            "_column_size_mobile": 100
