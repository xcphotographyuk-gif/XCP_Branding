          "elements": [
            {
              "id": "trust_p3_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Transparent Investment",
                "header_size": "h3"
              }
            },
            {
              "id": "trust_p3_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Sessions start from <strong>£1,495</strong>. Every proposal is tailored. No generic price lists, no hidden fees. You will know exactly what you are getting and what it costs before any commitment.</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "contact_trust_statement",
