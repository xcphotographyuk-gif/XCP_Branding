{
  "version": "0.4",
  "title": "XCP Home S5b - Final CTA",
  "type": "page",
  "content": [
    {
      "id": "s5b-cta-section",
      "elType": "section",
      "settings": {
        "_title": "Final CTA",
        "layout": "boxed",
        "background_background": "classic",
        "background_color": "#000000",
        "padding": {
          "unit": "px",
          "top": "90",
          "right": "20",
          "bottom": "90",
          "left": "20"
        }
      },
      "elements": [
        {
          "id": "s5b-cta-col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "s5b-cta-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Ready to Create Your Visual Impact?",
                "header_size": "h2",
                "align": "center",
                "typography_font_family": "Montserrat",
                "typography_font_weight": "700",
                "typography_font_size": {
                  "unit": "px",
                  "size": 42
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 34
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 28
                },
                "color": "#FFFFFF"
              }
            },
            {
              "id": "s5b-cta-text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 20px; line-height: 1.8; color: rgba(255,255,255,0.80); max-width: 680px; margin: 24px auto 0;'>Share your vision and let's craft imagery that reflects exactly who you are — and commands the attention of the right people.</p>"
              }
            },
            {
              "id": "s5b-cta-button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Start Your Journey",
                "link": {
                  "url": "/booking",
                  "is_external": false
                },
                "align": "center",
                "size": "lg",
                "background_color": "#d4af37",
                "button_text_color": "#000000",
                "border_radius": {
                  "unit": "px",
                  "top": "0",
                  "right": "0",
                  "bottom": "0",
                  "left": "0"
                },
                "margin": {
                  "unit": "px",
                  "top": "36",
                  "right": "0",
                  "bottom": "0",
                  "left": "0",
                  "isLinked": false
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
