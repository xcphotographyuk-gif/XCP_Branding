              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "From Vision to Visual Impact: Here's How It Works",
                "header_size": "h2",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 42
                }
              }
            }
          ]
        },
        {
          "id": "process-step-1",
          "elType": "column",
