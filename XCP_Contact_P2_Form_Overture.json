{
  "version": "0.4",
  "title": "XCP Contact: Form + Info Panel: OVERTURE VERSION: Section 2 of 4",
  "_comment": "PRIMARY FORM: Routes enquiries to Overture CRM via webhook (POST /api/bookings) AND sends email notification. Field IDs match Overture Booking API field names exactly so webhook data maps without transformation. API key: WordPress Admin → Elementor → Integrations → add Authorization header Bearer [YOUR_OVERTURE_API_KEY]. Webhook URL: [YOUR_OVERTURE_BASE_URL]/api/bookings. Field mapping: promoterName→Booking.promoterName, name→Booking.name (title), date→Booking.date, venueState→Booking.venueState, venueCountry→Booking.venueCountry, message→Booking.info[].",
  "type": "page",
  "content": [
    {
      "id": "contact_form_overture",
      "elType": "section",
      "settings": {
        "_title": "Contact Form: Overture (Primary)",
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1200
        },
        "structure": "20",
        "background_background": "classic",
        "background_color": "#ffffff",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        },
        "gap": "wide"
      },
      "elements": [
        {
          "id": "form_col_overture",
          "elType": "column",
          "settings": {
            "_column_size": 60,
            "_column_size_tablet": 100,
            "_column_size_mobile": 100,
            "padding": {
              "unit": "px",
              "top": "0",
              "right": "40",
              "bottom": "0",
              "left": "0",
              "isLinked": false
            }
          },
          "elements": [
            {
              "id": "form_eyebrow_o",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='font-size:12px;letter-spacing:2.5px;text-transform:uppercase;color:#888;font-weight:600;font-family:Raleway,sans-serif;margin-bottom:10px;'>Start the Conversation</p>"
              }
            },
            {
              "id": "form_heading_o",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Tell Me About Your Vision",
                "header_size": "h2",
                "typography_font_size": {
                  "unit": "px",
                  "size": 34
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 26
                }
              }
            },
            {
              "id": "form_intro_o",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='font-size:16px;line-height:1.7;color:#555;margin:12px 0 28px;'>No scripts, no pressure. Just an honest conversation about what you need and whether I'm the right fit to deliver it. I aim to respond within 24 hours.</p>"
              }
            },
            {
              "id": "contact_form_widget_overture",
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "XCP Contact: Overture",
                "form_fields": [
                  {
                    "field_type": "text",
                    "field_label": "Your Name",
                    "field_id": "promoterName",
                    "_comment": "Overture Booking API: promoterName — the client making the enquiry.",
                    "required": "yes",
                    "placeholder": "First and last name",
                    "width": "50"
                  },
                  {
                    "field_type": "email",
                    "field_label": "Email Address",
                    "field_id": "email",
                    "_comment": "Overture will use this to create or match a Person record.",
                    "required": "yes",
                    "placeholder": "hello@yourbrand.co.uk",
                    "width": "50"
                  },
                  {
                    "field_type": "tel",
                    "field_label": "Phone Number",
                    "field_id": "phone",
                    "_comment": "Overture will attach this to the Person record.",
                    "required": "no",
                    "placeholder": "+44 (0) 7XXX XXXXXX",
                    "width": "50"
                  },
                  {
                    "field_type": "select",
                    "field_label": "Type of Project",
                    "field_id": "name",
                    "_comment": "Overture Booking API: name — becomes the booking title in Overture.",
                    "required": "yes",
                    "field_options": "Brand Photography Session\nDocumentary Business Storytelling\nCorporate Portraits & Headshots\nEvent & Performance Coverage\nEditorial Work\nFine Art Commission\nWorkshop or Photography Course\nNot Sure Yet, Let's Talk",
                    "width": "50"
                  },
                  {
                    "field_type": "date",
                    "field_label": "Preferred Shoot Date (if known)",
                    "field_id": "date",
                    "_comment": "Overture Booking API: date — ISO 8601 date for the booking.",
                    "required": "no",
                    "placeholder": "Approximate date",
                    "width": "50"
                  },
                  {
                    "field_type": "text",
                    "field_label": "County / Region",
                    "field_id": "venueState",
                    "_comment": "Overture Booking API: venueState — county or region for the shoot location.",
                    "required": "no",
                    "placeholder": "e.g. East Sussex, Greater London",
                    "width": "50"
                  },
                  {
                    "field_type": "select",
                    "field_label": "Country",
                    "field_id": "venueCountry",
                    "_comment": "Overture Booking API: venueCountry — country for the shoot location.",
                    "required": "no",
                    "field_options": "United Kingdom\nInternational",
                    "default_value": "United Kingdom",
                    "width": "50"
                  },
                  {
                    "field_type": "textarea",
                    "field_label": "Tell Me About Your Brand & Vision",
                    "field_id": "message",
                    "_comment": "Overture Booking API: maps into the booking info[] array as a note.",
                    "required": "yes",
                    "placeholder": "What does your brand stand for? Who is your ideal client? What do you hope authentic photography will do for your business? The more you share, the better I can prepare.",
                    "rows": 6,
                    "width": "100"
                  },
                  {
                    "field_type": "hidden",
                    "field_label": "Source URL",
                    "field_id": "source",
                    "_comment": "Overture: page source URL. In Elementor, set Default Value to dynamic tag 'Current URL'.",
                    "required": "no",
                    "default_value": "[xcp_page_url]",
                    "width": "100"
                  },
                  {
                    "field_type": "acceptance",
                    "field_label": "Yes, I'd like to receive XC Photography updates \u2014 occasional news about availability, workshops, and editorial projects. No spam, unsubscribe any time.",
                    "field_id": "email_marketing_optin",
                    "required": "no",
                    "width": "100"
                  },
                  {
                    "field_type": "acceptance",
                    "field_label": "I have read and agree to the <a href='/privacy-policy' target='_blank' style='color:#1a1a1a;text-decoration:underline;'>Privacy Policy</a> and consent to XC Photography contacting me about my enquiry.",
                    "field_id": "gdpr_consent",
                    "required": "yes",
                    "width": "100",
                    "custom_messages": "yes",
                    "required_message": "Please confirm you have read and agree to the Privacy Policy before submitting."
                  }
                ],
                "submit_actions": [
                  "email",
                  "webhook"
                ],
                "webhook": "[YOUR_OVERTURE_BASE_URL]/api/bookings",
                "_comment_webhook_url": "Replace [YOUR_OVERTURE_BASE_URL] with your Overture instance URL, e.g. https://app.overture.studio. Endpoint: POST /api/bookings. Add Authorization header in Elementor form Advanced settings: Authorization: Bearer [YOUR_OVERTURE_API_KEY]. API key found in Overture Admin → Settings → Integrations → API Keys.",
                "webhook_advanced_data": "yes",
                "button_text": "Send My Enquiry",
                "button_size": "lg",
                "button_align": "left",
                "button_background_color": "#1a1a1a",
                "button_text_color": "#ffffff",
                "button_border_radius": {
                  "unit": "px",
                  "top": "0",
                  "right": "0",
                  "bottom": "0",
                  "left": "0",
                  "isLinked": true
                },
                "button_padding": {
                  "unit": "px",
                  "top": "16",
                  "right": "40",
                  "bottom": "16",
                  "left": "40",
                  "isLinked": false
                },
                "success_message": "Thank you. Your enquiry is on its way. I'll be in touch within 24 hours to arrange a discovery call.",
                "error_message": "Something went wrong. Please email me directly at hello@xcphotography.co.uk or call +44 (0) 7XXX XXXXXX.",
                "webhook_tags": "source:contact-form",
                "_comment_webhook": "Overture Booking API field mapping: promoterName→Booking.promoterName, name→Booking.name (title), date→Booking.date, venueState→Booking.venueState, venueCountry→Booking.venueCountry, message→Booking.info[], source→Booking source tag. status defaults to 'Pending' in Overture for all new bookings created via API."
              }
            }
          ]
        },
        {
          "id": "info_col_overture",
          "elType": "column",
          "settings": {
            "_column_size": 40,
            "_column_size_tablet": 100,
            "_column_size_mobile": 100,
            "background_background": "classic",
            "background_color": "#f8f8f8",
            "padding": {
              "unit": "px",
              "top": "50",
              "right": "40",
              "bottom": "50",
              "left": "40",
              "isLinked": false
            }
          },
          "elements": [
            {
              "id": "info_heading_o",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "What to Expect",
                "header_size": "h3",
                "typography_font_size": {
                  "unit": "px",
                  "size": 26
                }
              }
            },
            {
              "id": "info_steps_o",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<ol style='padding-left:20px;font-size:15px;line-height:1.9;color:#444;margin-top:16px;'><li style='margin-bottom:14px;'><strong>You send your enquiry</strong>. This form takes less than 3 minutes.</li><li style='margin-bottom:14px;'><strong>I respond within 24 hours</strong>, usually much sooner, with a few questions if I need them.</li><li style='margin-bottom:14px;'><strong>We have a free discovery call</strong>. 20 minutes, no pressure, just honest conversation.</li><li style='margin-bottom:14px;'><strong>I put together a tailored proposal</strong>, specific to your brand and goals, not a generic price list.</li><li><strong>We create something worth remembering.</strong></li></ol>"
              }
            },
            {
              "id": "info_divider_o",
              "elType": "widget",
              "widgetType": "divider",
              "settings": {
                "style": "solid",
                "color": "#dddddd",
                "gap": {
                  "unit": "px",
                  "size": 28
                }
              }
            },
            {
              "id": "info_contact_o",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Direct Contact",
                "header_size": "h4",
                "typography_font_size": {
                  "unit": "px",
                  "size": 18
                }
              }
            },
            {
              "id": "info_details_o",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='font-size:15px;line-height:1.8;color:#444;margin-top:12px;'><strong>Xavier Clarke</strong><br>XC Photography<br><br><a href='mailto:hello@xcphotography.co.uk' style='color:#1a1a1a;text-decoration:none;border-bottom:1px solid #E8E4DC;'>hello@xcphotography.co.uk</a><br><a href='tel:+441234567890' style='color:#1a1a1a;text-decoration:none;'>+44 (0) 1234 567890</a><br><br>Brighton-based \u00b7 UK & International<br>Mon\u2013Fri 9am\u20136pm \u00b7 Sat by appointment</p>"
              }
            },
            {
              "id": "info_note_o",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='background:#fff;border-left:3px solid #E8E4DC;padding:14px 18px;margin-top:24px;font-size:14px;line-height:1.7;color:#555;'><strong>Not ready to enquire?</strong><br>That's fine. <a href='/portfolio' style='color:#1a1a1a;text-decoration:underline;'>Browse the portfolio</a> first, or <a href='/stories' style='color:#1a1a1a;text-decoration:underline;'>read the blog</a> to see how I think about brand photography.</div>"
              }
            }
          ]
        }
      ]
    }
  ]
}