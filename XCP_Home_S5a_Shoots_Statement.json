{
  "version": "0.4",
  "title": "XCP Home S5a - Behind the Lens",
  "type": "page",
  "content": [
    {
      "id": "s5a-statement-section",
      "elType": "section",
      "settings": {
        "_title": "Behind the Lens Statement",
        "layout": "boxed",
        "background_background": "classic",
        "background_color": "#0a0a0a",
        "padding": {
          "unit": "px",
          "top": "90",
          "right": "20",
          "bottom": "60",
          "left": "20"
        }
      },
      "elements": [
        {
          "id": "s5a-statement-col",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "text_align": "center"
          },
          "elements": [
            {
              "id": "s5a-eyebrow",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Behind the Lens</p>"
              }
            },
            {
              "id": "s5a-statement-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "From Music Icons to Global Brands — Every Frame Earns Its Place",
                "header_size": "h2",
                "align": "center",
                "typography_font_family": "Montserrat",
                "typography_font_weight": "700",
                "typography_font_size": {
                  "unit": "px",
                  "size": 38
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 24
                },
                "color": "#e8e4dc"
              }
            },
            {
              "id": "s5a-statement-body",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 18px; line-height: 1.8; color: rgba(232,228,220,0.75); max-width: 740px; margin: 24px auto 0;'>XCP Photography has been trusted by household names and heritage venues alike. The brief is always the same — make it matter. The results speak for themselves.</p>"
              }
            }
          ]
        }
      ]
    },
    {
