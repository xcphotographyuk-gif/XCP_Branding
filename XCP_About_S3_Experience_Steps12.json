{
  "version": "0.4",
  "title": "About \u2013 Experience & Steps 1\u20132",
  "type": "page",
  "content": [
    {
      "id": "about_experience",
      "elType": "section",
      "settings": {
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1200
        },
        "padding": {
          "unit": "px",
          "top": 80,
          "right": 20,
          "bottom": 40,
          "left": 20
        },
        "_title": "The Experience"
      },
