              "id": "exp_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "What Working Together Looks Like",
                "header_size": "h2",
                "align": "center",
                "typography_font_size": {
                  "unit": "px",
                  "size": 42
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 28
                }
              }
            },
            {
              "id": "exp_intro",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 18px; max-width: 800px; margin: 30px auto;'>Collaboration, not transaction. Transparency, not mystery. Here's exactly how we'll work together to create imagery that elevates your brand.</p>"
              }
            }
          ]
        }
      ]
    },
